# =====================================================
# VisionAI Edge — Production .gitignore
# =====================================================

# ---- Node / SvelteKit ----
node_modules/
.output/
.vercel/
.netlify/
.wrangler/
/.svelte-kit/
/build/
/dist/

# ---- Vite ----
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ---- Python ----
venv/
.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
.eggs/
*.spec

# ---- Runtime / Generated Data ----
uploads/
uploads/generated/
logs/
temp/
tmp/
llm_cache.json
*.db
*.db-journal
*.sqlite
*.sqlite3

# ---- Environment & Secrets ----
.env
.env.*
backend/.env
!.env.example
!.env.test

# ---- Testing & Coverage ----
.pytest_cache/
.coverage
coverage/
htmlcov/
.tox/

# ---- IDE / OS ----
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
