# VisionAI Edge - Backend Environment Variables
# Copy this file to backend/.env. Never commit backend/.env.

# Ollama defaults are used when these values are omitted.
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_HOST=http://localhost:11434

# Required for AI Image Studio.
# Create a token with Inference Providers permission and accept the
# black-forest-labs/FLUX.1-schnell model terms before generating images.
HUGGINGFACE_API_KEY=hf_your_token_here
